# Network binding for local API server
API_HOST=0.0.0.0
API_PORT=8005

# Optional API key for protected endpoints (/predict, /predict-batch)
# Leave empty to disable auth in local development.
API_KEY=

# CORS
# Keep true in dev for convenience; set false in production.
ALLOW_ALL_ORIGINS=true
# Used only when ALLOW_ALL_ORIGINS=false
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173,http://localhost:8005,http://10.0.2.2:8005
